<UserControl x:Class="DhCodetaskExtension.ToolWindows.TrackerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="900" d:DesignWidth="340">

    <UserControl.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style x:Key="TimerBtn" TargetType="Button">
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10,10,10,14">

            <!-- Title -->
            <TextBlock Text="🎯 DevTask Tracker" FontWeight="Bold" FontSize="14" Margin="0,0,0,2"/>
            <TextBlock Text="{Binding StatusMessage}" FontSize="10" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <!-- ── URL Bar ───────────────────────────────────────────── -->
            <TextBlock Text="── 🔗 Task URL ──" Style="{StaticResource SectionLabel}"/>
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Clear" Style="{StaticResource ActionBtn}"
                        Command="{Binding ClearCommand}" Width="50" Margin="4,0,0,0"/>
                <Button DockPanel.Dock="Right" Content="Fetch" Style="{StaticResource ActionBtn}"
                        Command="{Binding FetchCommand}" Width="55"/>
                <TextBox x:Name="TxtUrl" Text="{Binding TaskUrl, UpdateSourceTrigger=PropertyChanged}"
                         Height="26" FontSize="11" Padding="4,2" VerticalContentAlignment="Center"
                         ToolTip="URL issue Gitea, ví dụ: http://localhost:3000/owner/repo/issues/1"/>
            </DockPanel>

            <!-- ── Task Info ─────────────────────────────────────────── -->
            <TextBlock Text="── 📌 Thông tin Task ──" Style="{StaticResource SectionLabel}"/>
            <TextBox Text="{Binding TaskTitle, UpdateSourceTrigger=PropertyChanged}"
                     Height="26" FontSize="12" FontWeight="SemiBold" Padding="4,2"
                     VerticalContentAlignment="Center" Margin="0,0,0,4"
                     ToolTip="Tiêu đề task"/>
            <TextBlock Text="{Binding LabelsDisplay}" FontSize="10" Foreground="#007ACC"
                       Margin="0,0,0,4" TextWrapping="Wrap"
                       Visibility="{Binding LabelsDisplay, Converter={StaticResource BoolVis}}"/>
            <TextBox Text="{Binding TaskDescription, UpdateSourceTrigger=PropertyChanged}"
                     Height="50" FontSize="11" Padding="4" AcceptsReturn="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     ToolTip="Mô tả task"/>

            <!-- ── Task Timer ────────────────────────────────────────── -->
            <TextBlock Text="── ⏱ Task Timer ──" Style="{StaticResource SectionLabel}"/>
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="8">
                <StackPanel>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding TimerState}"
                                   FontSize="10" Foreground="#888" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TimerDisplay}" FontSize="22" FontFamily="Consolas"
                                   FontWeight="Bold" Foreground="#007ACC"/>
                    </DockPanel>
                    <WrapPanel Margin="0,6,0,0">
                        <Button Content="▶ Start"   Style="{StaticResource TimerBtn}" Command="{Binding StartCommand}"/>
                        <Button Content="⏸ Pause"   Style="{StaticResource TimerBtn}" Command="{Binding PauseCommand}"/>
                        <Button Content="▶ Resume"  Style="{StaticResource TimerBtn}" Command="{Binding ResumeCommand}"/>
                        <Button Content="⏹ Stop"   Style="{StaticResource TimerBtn}" Command="{Binding StopCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ── Work Notes ────────────────────────────────────────── -->
            <TextBlock Text="── 📝 Work Notes ──" Style="{StaticResource SectionLabel}"/>
            <TextBox Text="{Binding WorkNotes, UpdateSourceTrigger=PropertyChanged}"
                     Height="70" FontSize="11" Padding="4" AcceptsReturn="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     ToolTip="Ghi chú quá trình làm việc"/>

            <!-- ── TODO List ──────────────────────────────────────────── -->
            <TextBlock Text="── ✅ TODO List ──" Style="{StaticResource SectionLabel}"/>
            <DockPanel Margin="0,0,0,4">
                <Button DockPanel.Dock="Right" Content="Add" Width="45" Height="26"
                        FontSize="11" Command="{Binding AddTodoCommand}" Margin="4,0,0,0"/>
                <TextBox Text="{Binding NewTodoText, UpdateSourceTrigger=PropertyChanged}"
                         Height="26" FontSize="11" Padding="4,2" VerticalContentAlignment="Center">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding AddTodoCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
            </DockPanel>

            <ItemsControl ItemsSource="{Binding Todos}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Text}" FontSize="11" TextWrapping="Wrap"
                                               TextDecorations="{Binding IsDone, Converter={StaticResource BoolVis}}"/>
                                    <TextBlock Text="{Binding ElapsedDisplay}" FontSize="10"
                                               Foreground="#007ACC" FontFamily="Consolas"/>
                                </StackPanel>
                                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Button Content="▶" Width="22" Height="22" FontSize="10" Margin="1"
                                            Command="{Binding StartCommand}" ToolTip="Start"/>
                                    <Button Content="⏸" Width="22" Height="22" FontSize="10" Margin="1"
                                            Command="{Binding PauseCommand}" ToolTip="Pause"/>
                                    <Button Content="✓" Width="22" Height="22" FontSize="10" Margin="1"
                                            Command="{Binding CompleteCommand}" ToolTip="Done"/>
                                    <Button Content="🗑" Width="22" Height="22" FontSize="10" Margin="1"
                                            Command="{Binding DeleteCommand}" ToolTip="Delete"/>
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- TODO summary -->
            <TextBlock Margin="0,4,0,0" FontSize="10" Foreground="#555">
                <Run Text="Tổng: "/><Run Text="{Binding TodoTotal}"/>
                <Run Text=" | Xong: "/><Run Text="{Binding TodoDone}"/>
                <Run Text=" | Đang: "/><Run Text="{Binding TodoRunning}"/>
                <Run Text=" | Tổng giờ: "/><Run Text="{Binding TodoTotalElapsed}"/>
            </TextBlock>

            <!-- ── Business Logic ────────────────────────────────────── -->
            <TextBlock Text="── 💼 Business Logic ──" Style="{StaticResource SectionLabel}"/>
            <TextBox Text="{Binding BusinessLogic, UpdateSourceTrigger=PropertyChanged}"
                     Height="70" FontSize="11" Padding="4" AcceptsReturn="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

            <!-- ── Commit Message ────────────────────────────────────── -->
            <TextBlock Text="── 🔀 Commit Message ──" Style="{StaticResource SectionLabel}"/>
            <DockPanel Margin="0,0,0,4">
                <Button DockPanel.Dock="Right" Content="↺" Width="30" Height="26"
                        FontSize="13" Command="{Binding RegenerateCommitCommand}"
                        Margin="4,0,0,0" ToolTip="Regenerate"/>
                <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                         Height="26" FontSize="11" Padding="4,2" VerticalContentAlignment="Center"/>
            </DockPanel>
            <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                     Height="50" FontSize="11" FontFamily="Consolas"
                     Padding="4" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>

            <!-- ── Actions ───────────────────────────────────────────── -->
            <Separator Margin="0,10,0,6"/>
            <WrapPanel>
                <Button Content="🚀 Push &amp; Complete" Height="32" FontSize="11" FontWeight="SemiBold"
                        Padding="10,0" Margin="0,0,4,4"
                        Command="{Binding PushAndCompleteCommand}"
                        IsEnabled="{Binding GitAvailable}"
                        ToolTip="Commit, push Git và hoàn thành task"/>
                <Button Content="⏸ Save &amp; Pause" Height="32" FontSize="11"
                        Padding="10,0" Margin="0,0,4,4"
                        Command="{Binding SaveAndPauseCommand}"
                        ToolTip="Lưu trạng thái và tạm dừng, không push git"/>
            </WrapPanel>
            <WrapPanel Margin="0,2,0,0">
                <Button Content="📚 Xem Lịch sử" Style="{StaticResource ActionBtn}"
                        x:Name="BtnHistory" Click="BtnHistory_Click"/>
                <Button Content="⚙ Settings" Style="{StaticResource ActionBtn}"
                        x:Name="BtnSettings" Click="BtnSettings_Click"/>
            </WrapPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
