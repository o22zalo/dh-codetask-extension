<Window x:Class="DhCodetaskExtension.ToolWindows.ReportDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📋 Chi tiết Report" Width="560" SizeToContent="Height"
        MaxHeight="700" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,14,16,14">
            <TextBlock x:Name="TxtTitle" FontSize="14" FontWeight="Bold" TextWrapping="Wrap"
                       Margin="0,0,0,10"/>

            <!-- Time info -->
            <Border Background="#F0F8FF" BorderBrush="#B0D8FF" BorderThickness="1"
                    CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock x:Name="TxtStarted" FontSize="11"/>
                    <TextBlock x:Name="TxtEnded" FontSize="11"/>
                    <TextBlock x:Name="TxtElapsed" FontSize="11" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- Sessions -->
            <TextBlock Text="Chi tiết các phiên làm việc:" FontSize="11" FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <DataGrid x:Name="GridSessions" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" FontSize="11" MaxHeight="130"
                      HeadersVisibility="Column" Margin="0,0,0,10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="30"/>
                    <DataGridTextColumn Header="Bắt đầu" Binding="{Binding Start}" Width="80"/>
                    <DataGridTextColumn Header="Kết thúc" Binding="{Binding End}" Width="80"/>
                    <DataGridTextColumn Header="Thời lượng" Binding="{Binding Duration}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Notes -->
            <TextBlock Text="📝 Ghi chú thực hiện:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtNotes" IsReadOnly="True" Height="60" FontSize="11"
                     Padding="4" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>

            <TextBlock Text="💼 Mô tả nghiệp vụ:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtBiz" IsReadOnly="True" Height="60" FontSize="11"
                     Padding="4" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>

            <!-- Todos -->
            <TextBlock x:Name="TxtTodoHeader" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <DataGrid x:Name="GridTodos" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" FontSize="11" MaxHeight="150"
                      HeadersVisibility="Column" Margin="0,0,0,10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="30"/>
                    <DataGridTextColumn Header="Nội dung" Binding="{Binding Text}" Width="*"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="80"/>
                    <DataGridTextColumn Header="Thời gian" Binding="{Binding Elapsed}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Commit -->
            <Border Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1"
                    CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock x:Name="TxtCommit" FontFamily="Consolas" FontSize="11"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="TxtGit" FontSize="10" Foreground="#555" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Separator Margin="0,4,0,8"/>

            <!-- Buttons -->
            <WrapPanel>
                <Button Content="📂 Mở .md" Height="28" Padding="10,0" FontSize="11"
                        Margin="0,0,6,0" Click="BtnOpenMd_Click"/>
                <Button Content="📂 Mở .json" Height="28" Padding="10,0" FontSize="11"
                        Margin="0,0,6,0" Click="BtnOpenJson_Click"/>
                <Button Content="✕ Đóng" Height="28" Padding="10,0" FontSize="11"
                        IsCancel="True" Click="BtnClose_Click"/>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
