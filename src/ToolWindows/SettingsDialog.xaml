<Window x:Class="DhCodetaskExtension.ToolWindows.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DH Codetask Extension — Settings (XML)"
        Width="480" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
    <StackPanel Margin="20,16,20,16">
        <TextBlock Text="⚙  Settings (XML)" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
        <TextBlock Text="Dùng DH Codetask Extension &gt; DevTask Settings... để cấu hình DevTaskTracker v3.0." FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
        <DockPanel Margin="0,0,0,4">
            <TextBlock Text="Server URL :" MinWidth="120" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0" FontSize="11"/>
            <TextBox x:Name="TxtServerUrl" Height="26" Padding="4,2" FontSize="11" VerticalContentAlignment="Center"/>
        </DockPanel>
        <DockPanel Margin="0,0,0,4">
            <TextBlock Text="API Key :" MinWidth="120" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0" FontSize="11"/>
            <PasswordBox x:Name="PwdApiKey" Height="26" Padding="4,2" FontSize="11" VerticalContentAlignment="Center"/>
        </DockPanel>
        <Border x:Name="ValidationBorder" Background="#FFF3E0" BorderBrush="#FF9800" BorderThickness="1" CornerRadius="3" Padding="8,5" Margin="0,8,0,0" Visibility="Collapsed">
            <TextBlock x:Name="TxtValidation" Foreground="#E65100" FontSize="11" TextWrapping="Wrap"/>
        </Border>
        <Separator Margin="0,12,0,12"/>
        <DockPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="BtnSave" Content="Save" Width="80" Height="28" Margin="0,0,8,0" FontSize="11" FontWeight="SemiBold" IsDefault="True" Click="BtnSave_Click"/>
                <Button Content="Cancel" Width="80" Height="28" FontSize="11" IsCancel="True" Click="BtnCancel_Click"/>
            </StackPanel>
        </DockPanel>
    </StackPanel>
</Window>
