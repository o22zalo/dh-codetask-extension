<Window x:Class="VS2017ExtensionTemplate.ToolWindows.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VS2017 Extension Template — Settings"
        Width="480" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="Margin" Value="130,2,0,6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20,16,20,16">

        <!-- Title -->
        <TextBlock Text="⚙  Settings" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- Server URL -->
        <DockPanel Margin="0,0,0,2">
            <TextBlock Text="Server URL :" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtServerUrl" Style="{StaticResource FieldInput}"
                     ToolTip="URL of the backend server"/>
        </DockPanel>
        <TextBlock Text="Example: https://api.example.com/v1" Style="{StaticResource HintText}"/>

        <!-- API Key -->
        <DockPanel Margin="0,0,0,2">
            <TextBlock Text="API Key :" Style="{StaticResource FieldLabel}"/>
            <PasswordBox x:Name="PwdApiKey" Height="26" Padding="4,2" FontSize="12"
                         VerticalContentAlignment="Center"
                         ToolTip="API key for authentication (leave blank if not required)"/>
        </DockPanel>
        <TextBlock Text="Leave blank if authentication is not required." Style="{StaticResource HintText}"/>

        <!-- Timeout -->
        <DockPanel Margin="0,0,0,2">
            <TextBlock Text="Timeout (s) :" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtTimeout" Style="{StaticResource FieldInput}"
                     Width="80" HorizontalAlignment="Left"
                     ToolTip="Request timeout in seconds (1–300)"/>
        </DockPanel>
        <TextBlock Text="Valid: 1–300. Default: 30." Style="{StaticResource HintText}"/>

        <!-- Max Results -->
        <DockPanel Margin="0,0,0,2">
            <TextBlock Text="Max Results :" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtMaxResults" Style="{StaticResource FieldInput}"
                     Width="80" HorizontalAlignment="Left"
                     ToolTip="Maximum number of results per query (1–1000)"/>
        </DockPanel>
        <TextBlock Text="Valid: 1–1000. Default: 50." Style="{StaticResource HintText}"/>

        <!-- Output Format -->
        <DockPanel Margin="0,0,0,2">
            <TextBlock Text="Output Format :" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="CmbOutputFormat" Height="26" FontSize="12"
                      Width="120" HorizontalAlignment="Left">
                <ComboBoxItem Content="JSON"/>
                <ComboBoxItem Content="XML"/>
                <ComboBoxItem Content="CSV"/>
                <ComboBoxItem Content="Plain Text"/>
            </ComboBox>
        </DockPanel>
        <TextBlock Text="Format used when writing data to the Output Window." Style="{StaticResource HintText}"/>

        <!-- Checkboxes -->
        <DockPanel Margin="0,6,0,4">
            <TextBlock Text="" Style="{StaticResource FieldLabel}"/>
            <StackPanel>
                <CheckBox x:Name="ChkDebug" Content="Debug Mode" Margin="0,0,0,6" FontSize="12"
                          ToolTip="Enable debug mode – log more detail to Output Window"/>
                <CheckBox x:Name="ChkEnableLogging" Content="Enable Logging" FontSize="12"
                          ToolTip="Log extension activity to the Output Window"/>
            </StackPanel>
        </DockPanel>

        <!-- Validation message -->
        <Border x:Name="ValidationBorder"
                Background="#FFF3E0" BorderBrush="#FF9800" BorderThickness="1"
                CornerRadius="3" Padding="8,5" Margin="0,8,0,0"
                Visibility="Collapsed">
            <TextBlock x:Name="TxtValidation" Foreground="#E65100"
                       FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <Separator Margin="0,12,0,12"/>

        <!-- Buttons -->
        <DockPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="BtnSave" Content="Save"
                        Width="80" Height="28" Margin="0,0,8,0"
                        FontSize="12" FontWeight="SemiBold"
                        IsDefault="True"
                        Click="BtnSave_Click"/>
                <Button x:Name="BtnCancel" Content="Cancel"
                        Width="80" Height="28"
                        FontSize="12"
                        IsCancel="True"
                        Click="BtnCancel_Click"/>
            </StackPanel>
        </DockPanel>

    </StackPanel>
</Window>
