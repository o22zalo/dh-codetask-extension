<UserControl x:Class="DhCodetaskExtension.ToolWindows.HistoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="500">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <Style x:Key="FilterBtn" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="GroupName" Value="ViewMode"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" BorderBrush="#CCC" BorderThickness="1"
                                CornerRadius="3" Padding="{TemplateBinding Padding}"
                                Background="White">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#007ACC"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#007ACC" Padding="10,8">
            <TextBlock Text="📚 TASK HISTORY" FontSize="13" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="8,6">
            <StackPanel>
                <WrapPanel>
                    <RadioButton Content="Hôm nay" Style="{StaticResource FilterBtn}"
                                 Checked="Filter_Today"/>
                    <RadioButton Content="Tuần này" Style="{StaticResource FilterBtn}"
                                 IsChecked="True" Checked="Filter_Week"/>
                    <RadioButton Content="Tháng này" Style="{StaticResource FilterBtn}"
                                 Checked="Filter_Month"/>
                    <RadioButton Content="Tùy chỉnh" Style="{StaticResource FilterBtn}"
                                 Checked="Filter_Custom"/>
                    <Button Content="🔄" Width="28" Height="26" FontSize="12" Margin="4,0,0,0"
                            ToolTip="Refresh" Click="BtnRefresh_Click"/>
                </WrapPanel>
                <!-- Custom range -->
                <WrapPanel x:Name="CustomRangePanel" Margin="0,4,0,0" Visibility="Collapsed">
                    <TextBlock Text="Từ:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                    <DatePicker x:Name="DpFrom" Width="110" FontSize="11"
                                SelectedDate="{Binding CustomFrom, Mode=TwoWay}"/>
                    <TextBlock Text="→" VerticalAlignment="Center" Margin="4,0" FontSize="11"/>
                    <DatePicker x:Name="DpTo" Width="110" FontSize="11"
                                SelectedDate="{Binding CustomTo, Mode=TwoWay}"/>
                    <Button Content="Lọc" Width="40" Height="26" FontSize="11" Margin="6,0,0,0"
                            Command="{Binding CustomFilterCommand}"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Search -->
        <Border Grid.Row="2" Padding="8,4" BorderBrush="#EEE" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="🔍" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="11" Height="24" Padding="4,2" VerticalContentAlignment="Center"
                         ToolTip="Tìm theo tiêu đề hoặc Task ID"/>
            </DockPanel>
        </Border>

        <!-- Summary Bar -->
        <Border Grid.Row="3" Background="#F5F5F5" Padding="8,6"
                BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <UniformGrid Columns="4">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Summary.TotalTasks}" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#007ACC"/>
                    <TextBlock Text="tasks" FontSize="9" Foreground="#888" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Summary.TotalElapsedDisplay}" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Foreground="#333"/>
                    <TextBlock Text="tổng" FontSize="9" Foreground="#888" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Summary.AvgElapsedDisplay}" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Foreground="#333"/>
                    <TextBlock Text="/ task" FontSize="9" Foreground="#888" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Summary.TodoDoneRateDisplay}" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Foreground="#4CAF50"/>
                    <TextBlock Text="TODO ✓" FontSize="9" Foreground="#888" HorizontalAlignment="Center"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- List -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"
                           Text="⏳ Đang tải..." Margin="12" FontSize="12" Foreground="#888"/>

                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#EEE" BorderThickness="0,0,0,1"
                                    Padding="10,8" Cursor="Hand"
                                    MouseLeftButtonUp="Item_Click"
                                    MouseLeftButtonDown="Item_MouseDown">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap">
                                            <Run Text="✅ #"/><Run Text="{Binding TaskId}"/>
                                            <Run Text=" "/><Run Text="{Binding TaskTitle}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="10" Foreground="#666" Margin="0,2,0,0">
                                            <Run Text="{Binding StartedAt, StringFormat=HH:mm}"/>
                                            <Run Text=" → "/>
                                            <Run Text="{Binding CompletedAt, StringFormat=HH:mm}"/>
                                            <Run Text=" │ ⏱ "/><Run Text="{Binding ElapsedDisplay}"/>
                                            <Run Text=" │ "/><Run Text="{Binding TodoDone}"/>
                                            <Run Text="/"/><Run Text="{Binding TodoTotal}"/>
                                            <Run Text=" ✓"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="🔀 Pushed" FontSize="9" Foreground="#4CAF50"
                                                   Visibility="{Binding WasPushed, Converter={StaticResource BoolVis}}"/>
                                        <Button Content="🗑" Width="24" Height="22" FontSize="10"
                                                Tag="{Binding}"
                                                Click="BtnDelete_Click" ToolTip="Xóa report"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="12" FontSize="11" Foreground="#888" TextAlignment="Center"
                           Text="Không có task nào trong khoảng này.">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <!-- Pagination -->
        <Border Grid.Row="5" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="8,6">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Export CSV" Height="26" FontSize="10"
                        Padding="8,0" Click="BtnExportCsv_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="◀ Prev" Height="26" Width="60" FontSize="10"
                            Command="{Binding PrevPageCommand}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding PageLabel}" VerticalAlignment="Center" FontSize="11"/>
                    <Button Content="Next ▶" Height="26" Width="60" FontSize="10"
                            Command="{Binding NextPageCommand}" Margin="8,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
