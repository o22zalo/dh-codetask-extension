<Window x:Class="VS2017ExtensionTemplate.ToolWindows.JsonSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VS2017 Extension Template — Settings (JSON)"
        Width="640" Height="580"
        MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">

    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static SystemColors.ActiveCaptionBrushKey}}"
                Padding="14,8">
            <StackPanel>
                <TextBlock Text="⚙  Settings (JSON)"
                           FontSize="13" FontWeight="Bold"
                           Foreground="{DynamicResource {x:Static SystemColors.ActiveCaptionTextBrushKey}}"/>
                <TextBlock Text="Edit configuration as JSON. Format, validate, then Save."
                           FontSize="10"
                           Foreground="{DynamicResource {x:Static SystemColors.ActiveCaptionTextBrushKey}}"
                           Opacity="0.85"/>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <WrapPanel>
                <Button x:Name="BtnFormat"   Content="✨ Format JSON"    Style="{StaticResource ToolBtn}" Click="BtnFormat_Click"   ToolTip="Reformat JSON with standard indentation"/>
                <Button x:Name="BtnValidate" Content="✔ Validate"        Style="{StaticResource ToolBtn}" Click="BtnValidate_Click" ToolTip="Check if JSON is syntactically valid"/>
                <Button x:Name="BtnReset"    Content="↩ Reset Default"   Style="{StaticResource ToolBtn}" Click="BtnReset_Click"    ToolTip="Load the default JSON schema"/>
                <Button x:Name="BtnReload"   Content="🔄 Reload from File" Style="{StaticResource ToolBtn}" Click="BtnReload_Click"  ToolTip="Reload from file, discard unsaved changes"/>
                <Separator Width="1" Margin="4,2" Background="Gray"/>
                <Button x:Name="BtnCopy"     Content="📋 Copy"           Style="{StaticResource ToolBtn}" Click="BtnCopy_Click"    ToolTip="Copy all JSON to clipboard"/>
                <Button x:Name="BtnPaste"    Content="📌 Paste"          Style="{StaticResource ToolBtn}" Click="BtnPaste_Click"   ToolTip="Paste JSON from clipboard"/>
            </WrapPanel>
        </Border>

        <!-- JSON editor -->
        <Border Grid.Row="2" Margin="10,8,10,0"
                BorderThickness="1"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="TxtJson"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas, Courier New, monospace"
                         FontSize="12" Padding="8"
                         BorderThickness="0"
                         VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         UndoLimit="100"
                         TextChanged="TxtJson_TextChanged"
                         ToolTip="Enter or paste JSON configuration. Ctrl+Z to undo."/>
            </ScrollViewer>
        </Border>

        <!-- Status bar -->
        <Grid Grid.Row="3" Margin="10,4,10,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="StatusBorder" Grid.Column="0"
                    CornerRadius="3" Padding="8,4"
                    Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="1">
                <TextBlock x:Name="TxtStatus" FontSize="11" TextWrapping="Wrap"
                           Text="✔  JSON loaded. Ready to edit."/>
            </Border>
            <TextBlock x:Name="TxtCounter" Grid.Column="1"
                       FontSize="10" Foreground="Gray"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0" Text="0 chars"/>
        </Grid>

        <Separator Grid.Row="4" Margin="0"/>

        <!-- Bottom buttons -->
        <DockPanel Grid.Row="5" Margin="10,8,10,10">
            <TextBlock DockPanel.Dock="Left" x:Name="TxtFilePath"
                       FontSize="9" Foreground="Gray" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" MaxWidth="280" Text="(file path)"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnSave"   Content="💾  Save"
                        Style="{StaticResource PrimaryBtn}" IsDefault="True"
                        Click="BtnSave_Click" ToolTip="Validate and save, log changed keys to Output"/>
                <Button x:Name="BtnCancel" Content="Cancel"
                        Style="{StaticResource ToolBtn}" IsCancel="True"
                        Click="BtnCancel_Click" Margin="0"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
