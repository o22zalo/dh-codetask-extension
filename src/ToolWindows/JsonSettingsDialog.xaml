<Window x:Class="DhCodetaskExtension.ToolWindows.JsonSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DH Codetask Extension — Settings (JSON)"
        Width="640" Height="580" MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.ActiveCaptionBrushKey}}" Padding="14,8">
            <TextBlock Text="⚙  Settings (JSON)" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource {x:Static SystemColors.ActiveCaptionTextBrushKey}}"/>
        </Border>
        <Border Grid.Row="1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="0,0,0,1" Padding="10,6">
            <WrapPanel>
                <Button x:Name="BtnFormat"   Content="✨ Format"      Height="26" Padding="10,0" FontSize="11" Margin="0,0,6,0" Click="BtnFormat_Click"/>
                <Button x:Name="BtnValidate" Content="✔ Validate"     Height="26" Padding="10,0" FontSize="11" Margin="0,0,6,0" Click="BtnValidate_Click"/>
                <Button x:Name="BtnReset"    Content="↩ Reset"        Height="26" Padding="10,0" FontSize="11" Margin="0,0,6,0" Click="BtnReset_Click"/>
                <Button x:Name="BtnReload"   Content="🔄 Reload"      Height="26" Padding="10,0" FontSize="11" Margin="0,0,6,0" Click="BtnReload_Click"/>
            </WrapPanel>
        </Border>
        <Border Grid.Row="2" Margin="10,8,10,0" BorderThickness="1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="TxtJson" AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                         FontFamily="Consolas, Courier New" FontSize="12" Padding="8" BorderThickness="0"
                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         UndoLimit="100" TextChanged="TxtJson_TextChanged"/>
            </ScrollViewer>
        </Border>
        <Grid Grid.Row="3" Margin="10,4,10,4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Border x:Name="StatusBorder" Grid.Column="0" CornerRadius="3" Padding="8,4" Background="#E8F5E9" BorderBrush="#4CAF50" BorderThickness="1">
                <TextBlock x:Name="TxtStatus" FontSize="11" TextWrapping="Wrap" Text="✔  JSON loaded."/>
            </Border>
            <TextBlock x:Name="TxtCounter" Grid.Column="1" FontSize="10" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0" Text="0 chars"/>
        </Grid>
        <Separator Grid.Row="4" Margin="0"/>
        <DockPanel Grid.Row="5" Margin="10,8,10,10">
            <TextBlock DockPanel.Dock="Left" x:Name="TxtFilePath" FontSize="9" Foreground="Gray" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="280" Text="(file path)"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnSave"   Content="💾  Save"   Height="26" Padding="16,0" FontSize="11" FontWeight="SemiBold" IsDefault="True" Margin="0,0,6,0" Click="BtnSave_Click"/>
                <Button x:Name="BtnCancel" Content="Cancel"     Height="26" Padding="10,0" FontSize="11" IsCancel="True" Click="BtnCancel_Click" Margin="0"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
